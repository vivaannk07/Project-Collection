#include <stdio.h>
#include <stdlib.h>

struct book {
    int id;
    char name[50];
    char author[50];
    int issued;
};

void addBook() {
    FILE *fp = fopen("library.dat", "ab");
    struct book b;

    printf("Enter ID: ");
    scanf("%d", &b.id);

    printf("Enter Book Name: ");
    scanf(" %[^\n]", b.name);

    printf("Enter Author: ");
    scanf(" %[^\n]", b.author);

    b.issued = 0;

    fwrite(&b, sizeof(b), 1, fp);
    fclose(fp);

    printf("Book Added!\n");
}

void displayBooks() {
    FILE *fp = fopen("library.dat", "rb");
    struct book b;

    printf("\n--- Books ---\n");

    while (fread(&b, sizeof(b), 1, fp)) {
        printf("ID: %d | %s | %s | %s\n",
               b.id, b.name, b.author,
               b.issued ? "Issued" : "Available");
    }

    fclose(fp);
}

void searchBook() {
    FILE *fp = fopen("library.dat", "rb");
    struct book b;
    int id, found = 0;

    printf("Enter ID to search: ");
    scanf("%d", &id);

    while (fread(&b, sizeof(b), 1, fp)) {
        if (b.id == id) {
            printf("Found: %s by %s (%s)\n",
                   b.name, b.author,
                   b.issued ? "Issued" : "Available");
            found = 1;
        }
    }

    if (!found)
        printf("Not Found!\n");

    fclose(fp);
}

void issueBook() {
    FILE *fp = fopen("library.dat", "rb+");
    struct book b;
    int id;

    printf("Enter ID to issue: ");
    scanf("%d", &id);

    while (fread(&b, sizeof(b), 1, fp)) {
        if (b.id == id && b.issued == 0) {
            b.issued = 1;

            fseek(fp, -sizeof(b), SEEK_CUR);
            fwrite(&b, sizeof(b), 1, fp);

            printf("Book Issued!\n");
            fclose(fp);
            return;
        }
    }

    printf("Book not available!\n");
    fclose(fp);
}

void returnBook() {
    FILE *fp = fopen("library.dat", "rb+");
    struct book b;
    int id;

    printf("Enter ID to return: ");
    scanf("%d", &id);

    while (fread(&b, sizeof(b), 1, fp)) {
        if (b.id == id && b.issued == 1) {
            b.issued = 0;

            fseek(fp, -sizeof(b), SEEK_CUR);
            fwrite(&b, sizeof(b), 1, fp);

            printf("Book Returned!\n");
            fclose(fp);
            return;
        }
    }

    printf("Invalid ID!\n");
    fclose(fp);
}

void deleteBook() {
    FILE *fp = fopen("library.dat", "rb");
    FILE *temp = fopen("temp.dat", "wb");

    struct book b;
    int id, found = 0;

    printf("Enter ID to delete: ");
    scanf("%d", &id);

    while (fread(&b, sizeof(b), 1, fp)) {
        if (b.id != id) {
            fwrite(&b, sizeof(b), 1, temp);
        } else {
            found = 1;
        }
    }

    fclose(fp);
    fclose(temp);

    remove("library.dat");
    rename("temp.dat", "library.dat");

    if (found)
        printf("Book Deleted!\n");
    else
        printf("Book Not Found!\n");
}

// MAIN MENU
int main() {
    int choice;

    while (1) {
        printf("\nLibrary Menu\n");
        printf("1. Add Book\n");
        printf("2. Display Books\n");
        printf("3. Search Book\n");
        printf("4. Issue Book\n");
        printf("5. Return Book\n");
        printf("6. Delete Book\n");
        printf("7. Exit\n");

        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addBook(); break;
            case 2: displayBooks(); break;
            case 3: searchBook(); break;
            case 4: issueBook(); break;
            case 5: returnBook(); break;
            case 6: deleteBook(); break;
            case 7: exit(0);
            default: printf("Invalid choice!\n");
        }
    }
}
